# RoboCop Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# Anthropic Claude API (cloud reasoning for complex situations)
ANTHROPIC_API_KEY=

# Ollama local LLM
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# Jetson network config (use environment variables, not hardcoded values)
# JETSON_IP=192.168.1.100

# Future integrations
# UBER_API_KEY=
# GOOGLE_PLACES_API_KEY=
# RESEND_API_KEY=
